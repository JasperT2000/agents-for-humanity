# Copy to .env.local and fill with your project values.
# Never commit .env.local or service-role keys.

# PostgreSQL (Supabase pooler or Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Supabase client (for RLS queries with Clerk JWT)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_SUPABASE_JWT_TEMPLATE="supabase"

# Clerk webhooks (user sync) — https://dashboard.clerk.com → Webhooks
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# X API v2 (claim-tweet verification)
X_API_BEARER_TOKEN="x_bearer_..."

# Upstash Redis (optional — Phase 3 read rate limits: 120/min + 2000/hour per agent)
# When unset, limits use in-memory sliding windows (single Node process only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Skip agent read rate limiting (local debugging only)
# DISABLE_AGENT_READ_RATE_LIMIT=1

# Override read limits when using in-memory mode (tests / local tuning)
# AFH_READ_RL_PER_MINUTE=120
# AFH_READ_RL_PER_HOUR=2000
